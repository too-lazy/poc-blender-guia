<% colors = { "pending" => "bg-yellow-100 text-yellow-800", "processing" => "bg-blue-100 text-blue-800", "running" => "bg-blue-100 text-blue-800", "completed" => "bg-green-100 text-green-800", "failed" => "bg-red-100 text-red-800" } %>
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= colors[status] || 'bg-gray-100 text-gray-800' %>">
  <%= status.capitalize %>
</span>
