<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-black text-gray-900"><%= @patient.name %></h1>
      <p class="text-sm text-gray-500 mt-1 font-medium"><%= @patient.email %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_patient_path(@patient), class: "brutalist-btn brutalist-btn-ghost" %>
      <%= link_to "+ New Case", new_patient_case_path(@patient), class: "brutalist-btn brutalist-btn-primary" %>
    </div>
  </div>

  <% if @patient.notes.present? %>
    <div class="brutalist-card p-6">
      <div class="text-xs font-black uppercase tracking-wider text-gray-500 mb-2">Notes</div>
      <p class="text-gray-700"><%= @patient.notes %></p>
    </div>
  <% end %>

  <div class="brutalist-card">
    <div class="px-6 py-4 border-b-2 border-black">
      <h2 class="text-lg font-black text-gray-900">Cases</h2>
    </div>
    <% if @cases.any? %>
      <div class="divide-y-2 divide-gray-200">
        <% @cases.each do |c| %>
          <%= link_to patient_case_path(@patient, c), class: "block px-6 py-4 hover:bg-cream transition-colors" do %>
            <div class="flex items-center justify-between">
              <div>
                <div class="font-bold text-gray-900"><%= c.description.truncate(80) %></div>
                <div class="text-xs text-gray-500 mt-1 font-medium">
                  <%= c.stl_file.attached? ? "✓ STL uploaded" : "No STL file" %> · <%= c.workflow_runs.count %> runs
                </div>
              </div>
              <%= render partial: "shared/status_badge", locals: { status: c.status } %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <p class="text-gray-400 text-lg font-bold">No cases yet.</p>
      </div>
    <% end %>
  </div>
</div>
