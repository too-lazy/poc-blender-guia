<div class="space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Pacientes</h1>
      <p class="text-slate-500">Gestiona los pacientes y sus casos ortodónticos.</p>
    </div>
    <%= link_to new_patient_path,
        class: "bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg text-sm shadow-sm shadow-sky-200 transition-all flex items-center gap-2 font-medium" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Nuevo Paciente
    <% end %>
  </div>

  <div class="relative max-w-sm">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input type="text" placeholder="Buscar pacientes..."
      class="w-full pl-10 pr-4 py-2 rounded-lg border border-sky-200 focus:outline-none focus:ring-2 focus:ring-sky-100 focus:border-sky-400 text-sm bg-white">
  </div>

  <div class="bg-white border border-sky-100 rounded-xl shadow-sm overflow-hidden">
    <% if @patients.any? %>
      <div class="divide-y divide-sky-50">
        <% @patients.each do |patient| %>
          <%= link_to patient_path(patient), class: "block px-6 py-4 hover:bg-sky-50/30 transition-colors" do %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-sky-400 to-sky-600 flex items-center justify-center text-white text-sm font-semibold shrink-0">
                  <%= patient.name.split.map(&:first).first(2).join.upcase %>
                </div>
                <div>
                  <p class="text-sm font-medium text-slate-900"><%= patient.name %></p>
                  <p class="text-xs text-slate-500"><%= patient.email %></p>
                </div>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs bg-sky-100 text-sky-800 font-medium">
                <%= patient.cases.count %> casos
              </span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <div class="w-16 h-16 bg-sky-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-slate-700 font-semibold mb-2">Sin pacientes aún</h3>
        <p class="text-sm text-slate-500 max-w-sm mx-auto">Agrega tu primer paciente para comenzar a generar guías ortodónticas 3D.</p>
      </div>
    <% end %>
  </div>
</div>
