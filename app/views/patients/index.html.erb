<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-black text-gray-900">Patients</h1>
    <%= link_to "+ New Patient", new_patient_path, class: "brutalist-btn brutalist-btn-primary" %>
  </div>

  <div class="brutalist-card">
    <% if @patients.any? %>
      <div class="divide-y-2 divide-gray-200">
        <% @patients.each do |patient| %>
          <%= link_to patient_path(patient), class: "block px-6 py-4 hover:bg-cream transition-colors" do %>
            <div class="flex items-center justify-between">
              <div>
                <div class="font-bold text-gray-900"><%= patient.name %></div>
                <div class="text-sm text-gray-500"><%= patient.email %></div>
              </div>
              <span class="brutalist-badge bg-gray-100 text-gray-800"><%= patient.cases.count %> cases</span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <p class="text-gray-400 text-lg font-bold">No patients yet.</p>
      </div>
    <% end %>
  </div>
</div>
