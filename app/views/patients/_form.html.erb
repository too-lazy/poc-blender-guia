<%= form_with(model: patient, class: "space-y-5") do |f| %>
  <% if patient.errors.any? %>
    <div class="bg-red-100 border-2 border-black text-red-900 px-4 py-3 font-bold text-sm shadow-brutal-sm">
      <% patient.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-bold text-gray-700 mb-2" %>
    <%= f.text_field :name, class: "brutalist-input w-full", required: true %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-bold text-gray-700 mb-2" %>
    <%= f.email_field :email, class: "brutalist-input w-full" %>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-bold text-gray-700 mb-2" %>
    <%= f.text_area :notes, rows: 3, class: "brutalist-input w-full" %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "brutalist-btn brutalist-btn-primary cursor-pointer" %>
    <%= link_to "Cancel", patients_path, class: "brutalist-btn brutalist-btn-ghost" %>
  </div>
<% end %>
