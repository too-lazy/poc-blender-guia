<% if @recent_runs.any? { |r| r.status.in?(%w[pending running]) } %>
  <meta http-equiv="refresh" content="5">
<% end %>

<div class="space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Quick Processes</h1>
      <p class="text-slate-500 mt-1">Workflows sin paciente asociado</p>
    </div>
    <%= link_to new_quick_process_path,
        class: "bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm transition-all flex items-center gap-2" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Nuevo Quick Process
    <% end %>
  </div>

  <% if @recent_runs.any? %>
    <div class="space-y-4">
      <% @recent_runs.each do |run| %>
        <div class="bg-white border border-sky-100 rounded-xl shadow-sm overflow-hidden" id="quick-run-<%= run.id %>">
          <%= link_to workflow_run_path(run), class: "block px-6 py-4 border-b border-sky-50 flex items-center justify-between hover:bg-sky-50/30 transition-colors" do %>
            <div class="flex items-center gap-4">
              <%= render partial: "shared/status_badge", locals: { status: run.status } %>
              <div>
                <span class="font-semibold text-slate-900">Run #<%= run.id %></span>
                <span class="text-sm text-slate-500 ml-2"><%= run.case.description&.truncate(50) || "Quick process" %></span>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <% if run.duration %>
                <span class="text-xs font-medium text-slate-500"><%= "%.1f" % run.duration %>s</span>
              <% end %>
              <span class="text-xs text-slate-400 font-medium"><%= time_ago_in_words(run.created_at) %> ago</span>
              <span class="text-xs font-medium text-sky-500">Ver detalles →</span>
            </div>
          <% end %>

          <div class="grid grid-cols-1 <%= run.render_output.attached? ? 'lg:grid-cols-3' : '' %>">
            <div class="<%= run.render_output.attached? ? 'lg:col-span-2' : '' %> p-4">
              <div class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
                <% if run.status.in?(%w[pending running]) %>
                  <span class="inline-block w-2 h-2 bg-amber-500 rounded-full animate-pulse mr-1"></span>
                <% end %>
                Log Output
              </div>
              <% if run.log_output.present? %>
                <pre class="text-xs text-slate-600 whitespace-pre-wrap bg-slate-50 border border-slate-200 rounded-lg p-3 max-h-48 overflow-y-auto font-mono"><%= run.log_output %></pre>
              <% elsif run.error_message.present? %>
                <pre class="text-xs text-red-700 whitespace-pre-wrap bg-red-50 border border-red-200 rounded-lg p-3 max-h-48 overflow-y-auto font-mono"><%= run.error_message %></pre>
              <% else %>
                <div class="text-sm text-slate-400 italic bg-slate-50 border border-slate-200 rounded-lg p-3">
                  <% if run.status == "pending" %>
                    Esperando para iniciar…
                  <% elsif run.status == "running" %>
                    Procesando… los logs aparecerán aquí.
                  <% else %>
                    Sin log output.
                  <% end %>
                </div>
              <% end %>
            </div>

            <% if run.render_output.attached? %>
              <div class="p-4 border-l border-sky-50" data-controller="lightbox">
                <div class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">Render Output</div>
                <div class="bg-sky-50/30 border border-sky-100 rounded-lg p-2 cursor-pointer hover:border-sky-300 transition-colors"
                     data-action="click->lightbox#open"
                     data-lightbox-src-value="<%= url_for(run.render_output) %>">
                  <%= image_tag url_for(run.render_output), class: "w-full h-auto rounded", alt: "Blender render output" %>
                </div>
                <div class="mt-2 flex items-center gap-2">
                  <span class="text-xs text-slate-400">Click para expandir</span>
                  <%= link_to "⬇ Descargar", rails_blob_path(run.render_output, disposition: "attachment"),
                      class: "text-xs font-medium text-sky-500 hover:underline" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white border border-sky-100 rounded-xl shadow-sm p-16 text-center">
      <div class="w-16 h-16 bg-sky-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <p class="text-slate-500 font-medium">Sin quick processes aún.</p>
      <p class="text-slate-400 text-sm mt-2">Sube un STL para empezar.</p>
    </div>
  <% end %>
</div>
