<% if @recent_runs.any? { |r| r.status.in?(%w[pending running]) } %>
  <meta http-equiv="refresh" content="5">
<% end %>

<div class="space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-black text-gray-900">Quick Processes</h1>
      <p class="text-gray-600 mt-1">Patient-free workflow runs</p>
    </div>
    <%= link_to "🚀 New Quick Process", new_quick_process_path, class: "brutalist-btn brutalist-btn-primary" %>
  </div>

  <% if @recent_runs.any? %>
    <div class="space-y-4">
      <% @recent_runs.each do |run| %>
        <div class="brutalist-card" id="quick-run-<%= run.id %>">
          <!-- Header -->
          <%= link_to workflow_run_path(run), class: "block px-6 py-4 border-b-2 border-black flex items-center justify-between hover:bg-cream transition-colors" do %>
            <div class="flex items-center gap-4">
              <%= render partial: "shared/status_badge", locals: { status: run.status } %>
              <div>
                <span class="font-black text-gray-900">Run #<%= run.id %></span>
                <span class="text-sm text-gray-500 ml-2"><%= run.case.description&.truncate(50) || "Quick process" %></span>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <% if run.duration %>
                <span class="text-xs font-bold text-gray-500"><%= "%.1f" % run.duration %>s</span>
              <% end %>
              <span class="text-xs text-gray-400 font-medium"><%= time_ago_in_words(run.created_at) %> ago</span>
              <span class="text-xs font-bold text-brand">View details →</span>
            </div>
          <% end %>

          <!-- Body: log + render -->
          <div class="grid grid-cols-1 <%= run.render_output.attached? ? 'lg:grid-cols-3' : '' %>">
            <!-- Log output -->
            <div class="<%= run.render_output.attached? ? 'lg:col-span-2' : '' %> p-4">
              <div class="text-xs font-black uppercase tracking-wider text-gray-500 mb-2">
                <% if run.status.in?(%w[pending running]) %>
                  <span class="inline-block w-2 h-2 bg-blue-500 rounded-full animate-pulse mr-1"></span>
                <% end %>
                Log Output
              </div>
              <% if run.log_output.present? %>
                <pre class="text-xs text-gray-600 whitespace-pre-wrap bg-cream border-2 border-gray-200 p-3 max-h-48 overflow-y-auto font-mono"><%= run.log_output %></pre>
              <% elsif run.error_message.present? %>
                <pre class="text-xs text-red-700 whitespace-pre-wrap bg-red-50 border-2 border-red-300 p-3 max-h-48 overflow-y-auto font-mono"><%= run.error_message %></pre>
              <% else %>
                <div class="text-sm text-gray-400 italic bg-cream border-2 border-gray-200 p-3">
                  <% if run.status == "pending" %>
                    Waiting to start…
                  <% elsif run.status == "running" %>
                    Processing… logs will appear here.
                  <% else %>
                    No log output.
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- Render preview -->
            <% if run.render_output.attached? %>
              <div class="p-4 border-l-0 lg:border-l-2 border-t-2 lg:border-t-0 border-black" data-controller="lightbox">
                <div class="text-xs font-black uppercase tracking-wider text-gray-500 mb-2">Render Output</div>
                <div class="bg-cream border-2 border-gray-200 p-2 cursor-pointer hover:border-brand transition-colors"
                     data-action="click->lightbox#open"
                     data-lightbox-src-value="<%= url_for(run.render_output) %>">
                  <%= image_tag url_for(run.render_output),
                      class: "w-full h-auto",
                      alt: "Blender render output" %>
                </div>
                <div class="mt-2 flex gap-2">
                  <span class="text-xs font-bold text-teal-700">📸 Click to expand</span>
                  <%= link_to "⬇ Download", rails_blob_path(run.render_output, disposition: "attachment"),
                      class: "text-xs font-bold text-brand hover:underline" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="brutalist-card p-16 text-center">
      <p class="text-gray-500 text-lg font-bold">No quick processes yet.</p>
      <p class="text-gray-400 text-sm mt-2">Upload an STL to get started!</p>
    </div>
  <% end %>
</div>
