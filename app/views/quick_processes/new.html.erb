<div class="space-y-8">
  <div>
    <h1 class="text-3xl font-black text-gray-900">Quick Process</h1>
    <p class="text-gray-600 mt-1">Upload an STL and run the Blender pipeline — no patient needed.</p>
  </div>

  <div class="brutalist-card p-8">
    <%= form_with(model: Case.new, url: quick_process_path, class: "space-y-6") do |f| %>
      <div>
        <%= f.label :description, "Description (optional)", class: "block text-sm font-bold text-gray-700 mb-2" %>
        <%= f.text_field :description,
            placeholder: "e.g. Test render, upper arch…",
            class: "brutalist-input w-full" %>
      </div>

      <div>
        <%= f.label :stl_file, "STL File", class: "block text-sm font-bold text-gray-700 mb-2" %>
        <div class="brutalist-card !border-dashed !border-2 p-8 text-center bg-cream">
          <%= f.file_field :stl_file, accept: ".stl",
              class: "block w-full text-sm text-gray-600 file:mr-4 file:py-3 file:px-6 file:border-2 file:border-black file:text-sm file:font-bold file:bg-accent file:text-black file:shadow-brutal-sm hover:file:bg-accent-hover file:cursor-pointer file:transition-colors" %>
          <p class="text-xs text-gray-500 mt-3">Upload a .stl file to process through the Blender pipeline</p>
        </div>
      </div>

      <div>
        <%= f.submit "🚀 Process STL", class: "brutalist-btn brutalist-btn-primary w-full text-center justify-center text-lg py-4" %>
      </div>
    <% end %>
  </div>
</div>
