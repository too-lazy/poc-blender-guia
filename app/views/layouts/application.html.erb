<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "IAppliances Alpha" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="IAppliances Alpha">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>body { font-family: 'Space Grotesk', system-ui, sans-serif; }</style>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#F8FFFE] text-slate-900">
    <div class="flex h-screen overflow-hidden">

      <!-- Sidebar -->
      <aside class="w-64 bg-white border-r border-sky-100 flex flex-col fixed inset-y-0 left-0 z-20">
        <!-- Logo -->
        <div class="h-16 flex items-center px-5 border-b border-sky-50">
          <%= link_to root_path, class: "flex items-center gap-2.5" do %>
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-9 h-9 drop-shadow-sm">
              <path d="M32 4C24.5 4 20 7 17 10C14 13 12 17 12 22C12 27 13 30 14 34C15 38 16 42 17 48C18 54 19 58 22 58C25 58 26 52 27 46C28 40 29 36 32 36C35 36 36 40 37 46C38 52 39 58 42 58C45 58 46 54 47 48C48 42 49 38 50 34C51 30 52 27 52 22C52 17 50 13 47 10C44 7 39.5 4 32 4Z"
                fill="url(#toothGrad)" stroke="#0EA5E9" stroke-width="2.5" stroke-linejoin="round"/>
              <path d="M22 18C25 15 28 14 32 14C36 14 39 15 42 18" stroke="#0EA5E9" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
              <defs>
                <linearGradient id="toothGrad" x1="32" y1="4" x2="32" y2="58" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#F0F9FF"/>
                  <stop offset="1" stop-color="#E0F2FE"/>
                </linearGradient>
              </defs>
            </svg>
            <div class="tracking-tight text-lg leading-none">
              <span class="text-blue-600 font-bold">IA</span><span class="text-slate-700 font-medium">ppliances</span>
            </div>
            <span class="ml-1 px-1.5 py-0.5 text-[10px] tracking-wider bg-sky-100 text-sky-700 rounded font-semibold">ALPHA</span>
          <% end %>
        </div>

        <!-- Nav -->
        <nav class="flex-1 overflow-y-auto py-6 px-4 space-y-1">
          <div class="nav-section-label">Principal</div>

          <%= link_to root_path,
              class: "nav-item #{request.path == '/' || request.path == '/dashboard' ? 'nav-item-active' : ''}" do %>
            <svg class="w-5 h-5 <%= request.path == '/' || request.path == '/dashboard' ? 'text-sky-600' : 'text-slate-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Dashboard
          <% end %>

          <%= link_to patients_path,
              class: "nav-item #{request.path.start_with?('/patients') ? 'nav-item-active' : ''}" do %>
            <svg class="w-5 h-5 <%= request.path.start_with?('/patients') ? 'text-sky-600' : 'text-slate-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Pacientes
          <% end %>

          <%= link_to new_quick_process_path,
              class: "nav-item #{request.path.start_with?('/quick_process') ? 'nav-item-active' : ''}" do %>
            <svg class="w-5 h-5 <%= request.path.start_with?('/quick_process') ? 'text-sky-600' : 'text-slate-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Quick Process
          <% end %>

          <div class="mt-8 nav-section-label">Sistema</div>

          <%= link_to status_path,
              class: "nav-item #{request.path == '/status' ? 'nav-item-active' : ''}" do %>
            <svg class="w-5 h-5 <%= request.path == '/status' ? 'text-sky-600' : 'text-slate-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            Actividad
          <% end %>
        </nav>

        <!-- User footer -->
        <div class="p-4 border-t border-sky-50">
          <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-sky-50/60 cursor-pointer transition-colors">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-sky-400 to-sky-600 flex items-center justify-center text-white text-xs font-semibold shrink-0">
              DR
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-slate-900 truncate font-medium">Dr. Ortodoncista</p>
              <p class="text-xs text-slate-500 truncate">Ortodoncista</p>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 ml-64 flex flex-col min-h-0 overflow-hidden">
        <!-- Top header -->
        <header class="h-16 bg-white border-b border-sky-100 flex items-center justify-between px-8 sticky top-0 z-10 shrink-0">
          <div class="flex items-center gap-4 flex-1">
            <div class="relative max-w-md w-full">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              <input type="text" placeholder="Buscar pacientes, casos o archivos..."
                class="w-full pl-10 pr-4 py-2 rounded-lg border border-sky-200 focus:outline-none focus:ring-2 focus:ring-sky-100 focus:border-sky-400 text-sm transition-all bg-sky-50/30">
            </div>
          </div>
          <div class="flex items-center gap-4">
            <button class="relative p-2 rounded-full hover:bg-sky-50 text-slate-500 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
              </svg>
            </button>
            <%= link_to new_quick_process_path,
                class: "bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg text-sm shadow-sm shadow-sky-200 transition-all flex items-center gap-2 font-medium" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Nuevo Workflow
            <% end %>
          </div>
        </header>

        <!-- Flash messages -->
        <% if notice %>
          <div class="mx-8 mt-4 bg-sky-50 border border-sky-200 text-sky-800 px-4 py-3 rounded-lg text-sm font-medium shrink-0">
            ✓ <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="mx-8 mt-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm font-medium shrink-0">
            ⚠ <%= alert %>
          </div>
        <% end %>

        <!-- Page content -->
        <div class="flex-1 overflow-auto p-8 bg-[#F8FFFE]">
          <%= yield %>
        </div>

        <!-- Footer -->
        <footer class="px-8 py-3 border-t border-sky-50 bg-white text-center shrink-0">
          <p class="text-xs text-slate-400">
            <span class="text-blue-600 font-semibold">IA</span><span class="text-slate-500 font-medium">ppliances</span>
            Alpha · Blender Dental Guide Pipeline
          </p>
        </footer>
      </main>
    </div>
  </body>
</html>
