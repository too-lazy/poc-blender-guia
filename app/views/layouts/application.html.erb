<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "IAppliances Alpha" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="IAppliances Alpha">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>body { font-family: 'Space Grotesk', system-ui, sans-serif; }</style>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-cream min-h-screen">
    <nav class="bg-white border-b-3 border-black">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to root_path, class: "flex items-center gap-3 group" do %>
              <span class="text-2xl">🦷</span>
              <span class="text-xl font-black tracking-tight text-gray-900">IAppliances</span>
              <span class="brutalist-badge bg-brand-light text-brand !border-brand !py-0.5 !text-[10px]">Alpha</span>
            <% end %>
          </div>
          <div class="flex items-center gap-1">
            <%= link_to "Dashboard", root_path,
                class: "px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-100 border-2 border-transparent hover:border-black transition-all" %>
            <%= link_to "Patients", patients_path,
                class: "px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-100 border-2 border-transparent hover:border-black transition-all" %>
            <%= link_to "Status", status_path,
                class: "px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-100 border-2 border-transparent hover:border-black transition-all" %>
            <%= link_to "Quick Process", new_quick_process_path,
                class: "px-3 py-2 text-sm font-bold text-accent hover:bg-teal-50 border-2 border-transparent hover:border-black transition-all" %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-green-100 border-2 border-black text-green-900 px-4 py-3 font-bold text-sm shadow-brutal-sm">✓ <%= notice %></div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-red-100 border-2 border-black text-red-900 px-4 py-3 font-bold text-sm shadow-brutal-sm">⚠ <%= alert %></div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <footer class="border-t-2 border-black bg-white mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <p class="text-xs font-bold text-gray-500 text-center">IAppliances Alpha · Blender Dental Guide Pipeline</p>
      </div>
    </footer>
  </body>
</html>
