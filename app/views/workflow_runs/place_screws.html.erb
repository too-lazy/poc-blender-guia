<div class="space-y-6">
  <!-- Breadcrumb -->
  <div class="text-sm font-medium text-slate-500 flex items-center gap-1.5">
    <% if @patient %>
      <%= link_to @patient.name, patient_path(@patient), class: "text-sky-500 hover:text-sky-600" %> ›
      <%= link_to @case.description.truncate(40), patient_case_path(@patient, @case), class: "text-sky-500 hover:text-sky-600" %> ›
    <% else %>
      <%= link_to "Quick Processes", new_quick_process_path, class: "text-sky-500 hover:text-sky-600" %> ›
    <% end %>
    <%= link_to "Run ##{@run.id}", workflow_run_path(@run), class: "text-sky-500 hover:text-sky-600" %> ›
    <span class="text-slate-700">Colocación de Tornillos</span>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Colocación de Tornillos</h1>
      <p class="text-slate-500 mt-1">Haz click en el modelo para posicionar los tornillos de anclaje</p>
    </div>
  </div>

  <!-- 3D Screw Placement Viewer -->
  <% stl_upper = @case.upper_arch_file.attached? ? @case.upper_arch_file : @case.stl_file %>
  <% stl_lower = @case.lower_arch_file.attached? ? @case.lower_arch_file : nil %>
  <% if stl_upper&.attached? %>
    <div class="bg-white border border-sky-100 rounded-xl shadow-sm overflow-hidden"
         data-controller="screw-placer"
         data-screw-placer-upper-url-value="<%= rails_blob_url(stl_upper, disposition: :inline) %>"
         <%= stl_lower&.attached? ? "data-screw-placer-lower-url-value=\"#{rails_blob_url(stl_lower, disposition: :inline)}\"".html_safe : "" %>
         data-screw-placer-existing-value="<%= @case.screw_positions.to_json %>">

      <!-- Toolbar -->
      <div class="px-4 py-3 border-b border-sky-50 flex items-center justify-between flex-wrap gap-2">
        <div class="flex items-center gap-2">
          <span class="px-2.5 py-1 bg-amber-100 text-amber-800 rounded-full text-xs font-semibold" data-screw-placer-target="counter">0 tornillos</span>
        </div>

        <div class="flex items-center gap-1 flex-wrap">
          <!-- Camera presets -->
          <div class="flex items-center gap-1 border-r border-sky-100 pr-2 mr-1">
            <button data-action="click->screw-placer#viewTop" title="Vista superior"
              class="bg-sky-50 hover:bg-sky-100 text-sky-700 w-8 h-8 rounded-lg text-xs font-bold flex items-center justify-center transition-all">
              ⬆
            </button>
            <button data-action="click->screw-placer#viewFront" title="Vista frontal"
              class="bg-sky-50 hover:bg-sky-100 text-sky-700 w-8 h-8 rounded-lg text-xs font-bold flex items-center justify-center transition-all">
              ◉
            </button>
            <button data-action="click->screw-placer#viewRight" title="Vista lateral"
              class="bg-sky-50 hover:bg-sky-100 text-sky-700 w-8 h-8 rounded-lg text-xs font-bold flex items-center justify-center transition-all">
              ➡
            </button>
          </div>

          <!-- Zoom -->
          <div class="flex items-center gap-1 border-r border-sky-100 pr-2 mr-1">
            <button data-action="click->screw-placer#zoomIn" title="Acercar"
              class="bg-sky-50 hover:bg-sky-100 text-sky-700 w-8 h-8 rounded-lg text-sm font-bold flex items-center justify-center transition-all">
              +
            </button>
            <button data-action="click->screw-placer#zoomOut" title="Alejar"
              class="bg-sky-50 hover:bg-sky-100 text-sky-700 w-8 h-8 rounded-lg text-sm font-bold flex items-center justify-center transition-all">
              −
            </button>
            <button data-action="click->screw-placer#zoomFit" title="Centrar modelo"
              class="bg-sky-50 hover:bg-sky-100 text-sky-700 px-2 h-8 rounded-lg text-xs font-medium flex items-center justify-center transition-all">
              ⊞ Centrar
            </button>
          </div>

          <!-- Display -->
          <div class="flex items-center gap-1 border-r border-sky-100 pr-2 mr-1">
            <button data-action="click->screw-placer#toggleWireframe"
              class="bg-sky-50 hover:bg-sky-100 text-sky-700 px-2 h-8 rounded-lg text-xs font-medium flex items-center justify-center transition-all">
              ▦ Wire
            </button>
          </div>

          <!-- Screw actions -->
          <div class="flex items-center gap-1">
            <button data-action="click->screw-placer#undo"
              class="bg-red-50 hover:bg-red-100 text-red-600 px-2 h-8 rounded-lg text-xs font-medium flex items-center justify-center transition-all">
              ↩ Deshacer
            </button>
            <button data-action="click->screw-placer#clearAll"
              class="bg-red-50 hover:bg-red-100 text-red-600 px-2 h-8 rounded-lg text-xs font-medium flex items-center justify-center transition-all">
              🗑 Limpiar
            </button>
          </div>
        </div>
      </div>

      <!-- 3D Canvas -->
      <div data-screw-placer-target="container" style="width:100%;height:550px;cursor:crosshair;"></div>

      <!-- Help bar -->
      <div class="px-4 py-2 border-t border-sky-50 bg-sky-50/30 flex items-center justify-between">
        <p class="text-xs text-slate-500">
          <strong>Click izquierdo</strong> colocar tornillo ·
          <strong>Arrastra</strong> rotar ·
          <strong>Scroll</strong> zoom ·
          <strong>Click derecho</strong> mover
        </p>
      </div>

      <!-- Coordinates table -->
      <div class="border-t border-sky-100 px-4 py-3 max-h-64 overflow-y-auto" data-screw-placer-target="screwTable">
        <p class="text-sm text-slate-400 italic py-4 text-center">Haz click en el modelo para colocar tornillos</p>
      </div>
    </div>
  <% end %>

  <!-- Save form -->
  <%= form_with url: save_screws_workflow_run_path(@run), method: :patch, data: { turbo: false, controller: "screw-form", screw_form_placer_outlet: "[data-controller='screw-placer']" } do |f| %>
    <div data-screw-form-target="fields"></div>
    <div class="flex items-center justify-between mt-4">
      <div class="text-sm text-slate-500" data-screw-form-target="summary">
        Sin tornillos colocados
      </div>
      <div class="flex items-center gap-3">
        <%= link_to "← Volver al run", workflow_run_path(@run),
            class: "text-slate-500 hover:text-slate-700 px-4 py-2.5 rounded-lg text-sm font-medium transition-all" %>
        <%= f.submit "Guardar Posiciones y Generar Guía",
            class: "bg-sky-500 hover:bg-sky-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium shadow-sm transition-all cursor-pointer",
            data: { screw_form_target: "submitBtn" } %>
      </div>
    </div>
  <% end %>
</div>
