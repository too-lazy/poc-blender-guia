<% if @run.status.in?(%w[pending running]) %>
  <script>setTimeout(() => { window.location.reload() }, 5000)</script>
<% end %>

<div class="space-y-6">
  <!-- Breadcrumb -->
  <div class="text-sm font-medium text-slate-500 flex items-center gap-1.5">
    <% if @patient %>
      <%= link_to @patient.name, patient_path(@patient), class: "text-sky-500 hover:text-sky-600" %> ›
      <%= link_to @case.description.truncate(40), patient_case_path(@patient, @case), class: "text-sky-500 hover:text-sky-600" %> ›
    <% else %>
      <%= link_to "Quick Processes", new_quick_process_path, class: "text-sky-500 hover:text-sky-600" %> ›
      <span class="text-slate-600"><%= @case.description&.truncate(40) || "Quick process" %></span> ›
    <% end %>
    <span class="text-slate-700">Run #<%= @run.id %></span>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Workflow Run #<%= @run.id %></h1>
      <div class="flex items-center gap-3 mt-2">
        <%= render partial: "shared/status_badge", locals: { status: @run.status } %>
        <% if @run.duration %>
          <span class="text-sm text-slate-500 font-medium">Duración: <%= "%.1f" % @run.duration %>s</span>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <% if @run.render_output.attached? %>
        <%= link_to rails_blob_path(@run.render_output, disposition: "attachment"),
            class: "bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm transition-all flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          PNG Render
        <% end %>
      <% end %>
      <% if @case.stl_file.attached? %>
        <%= link_to rails_blob_path(@case.stl_file, disposition: "attachment"),
            class: "bg-white hover:bg-sky-50 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium border border-sky-200 transition-all flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          STL File
        <% end %>
      <% else %>
        <% if @case.upper_arch_file.attached? %>
          <%= link_to rails_blob_path(@case.upper_arch_file, disposition: "attachment"),
              class: "bg-white hover:bg-sky-50 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium border border-sky-200 transition-all flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Arco Superior
          <% end %>
        <% end %>
        <% if @case.lower_arch_file.attached? %>
          <%= link_to rails_blob_path(@case.lower_arch_file, disposition: "attachment"),
              class: "bg-white hover:bg-sky-50 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium border border-sky-200 transition-all flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Arco Inferior
          <% end %>
        <% end %>
      <% end %>
      <% if @run.status == "completed" && (@case.upper_arch_file.attached? || @case.stl_file.attached?) %>
        <%= link_to place_screws_workflow_run_path(@run),
            class: "bg-amber-500 hover:bg-amber-600 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm transition-all flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Colocar Tornillos
        <% end %>
      <% end %>
      <% if @case.guide_stl_file.attached? %>
        <%= link_to rails_blob_path(@case.guide_stl_file, disposition: "attachment"),
            class: "bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm transition-all flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Descargar Guía STL
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Timestamps -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white border border-sky-100 rounded-xl p-4 shadow-sm">
      <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Creado</div>
      <div class="text-sm font-medium text-slate-900 mt-1"><%= @run.created_at.strftime("%Y-%m-%d %H:%M:%S") %></div>
    </div>
    <div class="bg-white border border-sky-100 rounded-xl p-4 shadow-sm">
      <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Iniciado</div>
      <div class="text-sm font-medium text-slate-900 mt-1"><%= @run.started_at&.strftime("%Y-%m-%d %H:%M:%S") || "—" %></div>
    </div>
    <div class="bg-white border border-sky-100 rounded-xl p-4 shadow-sm">
      <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Completado</div>
      <div class="text-sm font-medium text-slate-900 mt-1"><%= @run.completed_at&.strftime("%Y-%m-%d %H:%M:%S") || "—" %></div>
    </div>
  </div>

  <!-- 3D STL Viewer -->
  <% stl_upper = @case.stl_file.attached? ? @case.stl_file : (@case.upper_arch_file.attached? ? @case.upper_arch_file : nil) %>
  <% stl_lower = @case.lower_arch_file.attached? ? @case.lower_arch_file : nil %>
  <% if stl_upper %>
    <div class="bg-white border border-sky-100 rounded-xl shadow-sm overflow-hidden"
         data-controller="stl-viewer"
         data-stl-viewer-url-value="<%= rails_blob_url(stl_upper, disposition: :inline) %>"
         <%= stl_lower ? "data-stl-viewer-lower-url-value=\"#{rails_blob_url(stl_lower, disposition: :inline)}\"".html_safe : "" %>>
      <div class="px-6 py-4 border-b border-sky-50 flex items-center justify-between">
        <h2 class="text-slate-900 font-semibold">Visor 3D del Modelo</h2>
        <div class="flex items-center gap-2">
          <button data-action="click->stl-viewer#toggleWireframe"
            class="bg-white hover:bg-sky-50 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-medium border border-sky-200 transition-all">
            Wireframe
          </button>
          <button data-action="click->stl-viewer#resetView"
            class="bg-white hover:bg-sky-50 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-medium border border-sky-200 transition-all">
            Reset Vista
          </button>
        </div>
      </div>
      <div data-stl-viewer-target="container" style="width:100%;height:500px;"></div>
      <div class="px-6 py-3 border-t border-sky-50 bg-sky-50/30">
        <p class="text-xs text-slate-500">Arrastra para rotar · Scroll para zoom · Click derecho para mover</p>
      </div>
    </div>
  <% end %>

  <!-- Render Output -->
  <% if @run.render_output.attached? %>
    <div class="bg-white border border-sky-100 rounded-xl shadow-sm p-6" data-controller="lightbox">
      <h2 class="text-slate-900 font-semibold mb-4">Blender Render</h2>
      <div class="bg-sky-50/30 border border-sky-100 rounded-xl p-4 flex justify-center cursor-pointer hover:border-sky-300 transition-colors"
           data-action="click->lightbox#open"
           data-lightbox-src-value="<%= url_for(@run.render_output) %>">
        <%= image_tag url_for(@run.render_output), class: "max-w-full max-h-96 rounded-lg", alt: "Occlusal render" %>
      </div>
      <div class="mt-4 flex items-center justify-center gap-4">
        <span class="text-xs text-slate-400">Haz click en la imagen para ver tamaño completo</span>
        <%= link_to rails_blob_path(@run.render_output, disposition: "attachment"),
            class: "bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg text-xs font-medium shadow-sm transition-all flex items-center gap-2" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Descargar PNG
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Error -->
  <% if @run.error_message.present? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-6">
      <h2 class="text-sm font-semibold text-red-900 mb-2 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        Error
      </h2>
      <pre class="text-xs text-red-800 whitespace-pre-wrap font-mono"><%= @run.error_message %></pre>
    </div>
  <% end %>

  <!-- Log Output -->
  <% if @run.log_output.present? %>
    <div class="bg-white border border-sky-100 rounded-xl shadow-sm p-6">
      <h2 class="text-sm font-semibold text-slate-900 mb-3">Log Output</h2>
      <pre class="text-xs text-slate-600 whitespace-pre-wrap bg-slate-50 border border-slate-200 rounded-lg p-4 max-h-96 overflow-y-auto font-mono"><%= @run.log_output %></pre>
    </div>
  <% end %>
</div>
