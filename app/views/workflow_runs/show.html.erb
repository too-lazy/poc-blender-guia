<% if @run.status.in?(%w[pending running]) %>
  <meta http-equiv="refresh" content="5">
<% end %>

<div class="space-y-6">
  <!-- Breadcrumb -->
  <div class="text-sm font-bold text-gray-500">
    <% if @patient %>
      <%= link_to @patient.name, patient_path(@patient), class: "text-brand hover:underline" %> ›
      <%= link_to @case.description.truncate(40), patient_case_path(@patient, @case), class: "text-brand hover:underline" %> ›
    <% else %>
      <%= link_to "Quick Processes", quick_process_path, class: "text-brand hover:underline" %> ›
      <span class="text-gray-600"><%= @case.description&.truncate(40) || "Quick process" %></span> ›
    <% end %>
    <span class="text-gray-700">Run #<%= @run.id %></span>
  </div>

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-black text-gray-900">Workflow Run #<%= @run.id %></h1>
      <div class="flex items-center gap-3 mt-3">
        <%= render partial: "shared/status_badge", locals: { status: @run.status } %>
        <% if @run.duration %>
          <span class="text-sm text-gray-500 font-medium">Duration: <%= "%.1f" % @run.duration %>s</span>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Timestamps -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="brutalist-card p-4">
      <div class="text-xs font-black uppercase tracking-wider text-gray-500">Created</div>
      <div class="text-sm font-bold text-gray-900 mt-1"><%= @run.created_at.strftime("%Y-%m-%d %H:%M:%S") %></div>
    </div>
    <div class="brutalist-card p-4">
      <div class="text-xs font-black uppercase tracking-wider text-gray-500">Started</div>
      <div class="text-sm font-bold text-gray-900 mt-1"><%= @run.started_at&.strftime("%Y-%m-%d %H:%M:%S") || "—" %></div>
    </div>
    <div class="brutalist-card p-4">
      <div class="text-xs font-black uppercase tracking-wider text-gray-500">Completed</div>
      <div class="text-sm font-bold text-gray-900 mt-1"><%= @run.completed_at&.strftime("%Y-%m-%d %H:%M:%S") || "—" %></div>
    </div>
  </div>

  <!-- Render Output -->
  <% if @run.render_output.attached? %>
    <div class="brutalist-card p-6" data-controller="lightbox">
      <h2 class="text-lg font-black text-gray-900 mb-4">Render Output</h2>
      <div class="bg-cream border-2 border-black p-4 flex justify-center cursor-pointer hover:border-brand transition-colors"
           data-action="click->lightbox#open"
           data-lightbox-src-value="<%= url_for(@run.render_output) %>">
        <%= image_tag url_for(@run.render_output), class: "max-w-full max-h-96", alt: "Occlusal render" %>
      </div>
      <div class="mt-4 flex items-center justify-center gap-4">
        <span class="text-xs font-bold text-gray-500">📸 Click image to view full size</span>
        <%= link_to "⬇ Download PNG", rails_blob_path(@run.render_output, disposition: "attachment"), class: "brutalist-btn brutalist-btn-accent !py-2 !px-4 !text-xs" %>
      </div>
    </div>
  <% end %>

  <!-- Error -->
  <% if @run.error_message.present? %>
    <div class="bg-red-100 border-2 border-black p-6 shadow-brutal">
      <h2 class="text-sm font-black text-red-900 mb-2">⚠ Error</h2>
      <pre class="text-xs text-red-800 whitespace-pre-wrap font-mono"><%= @run.error_message %></pre>
    </div>
  <% end %>

  <!-- Log Output -->
  <% if @run.log_output.present? %>
    <div class="brutalist-card p-6">
      <h2 class="text-sm font-black text-gray-900 mb-3">Log Output</h2>
      <pre class="text-xs text-gray-600 whitespace-pre-wrap bg-cream border-2 border-gray-300 p-4 max-h-96 overflow-y-auto font-mono"><%= @run.log_output %></pre>
    </div>
  <% end %>
</div>
