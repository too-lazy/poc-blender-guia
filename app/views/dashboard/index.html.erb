<div class="space-y-8">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <%= link_to "New Patient", new_patient_path, class: "bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700" %>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <div class="text-sm font-medium text-gray-500">Patients</div>
      <div class="text-3xl font-bold text-gray-900 mt-1"><%= Patient.count %></div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <div class="text-sm font-medium text-gray-500">Cases</div>
      <div class="text-3xl font-bold text-gray-900 mt-1"><%= Case.count %></div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <div class="text-sm font-medium text-gray-500">Workflow Runs</div>
      <div class="text-3xl font-bold text-gray-900 mt-1"><%= WorkflowRun.count %></div>
    </div>
  </div>

  <!-- Recent Runs -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Workflow Runs</h2>
    </div>
    <% if @recent_runs.any? %>
      <div class="divide-y divide-gray-100">
        <% @recent_runs.each do |run| %>
          <div class="px-6 py-4 flex items-center justify-between">
            <div>
              <div class="font-medium text-gray-900"><%= run.case.patient.name %></div>
              <div class="text-sm text-gray-500"><%= run.case.description.truncate(60) %></div>
            </div>
            <div class="flex items-center space-x-3">
              <%= render partial: "shared/status_badge", locals: { status: run.status } %>
              <span class="text-xs text-gray-400"><%= time_ago_in_words(run.created_at) %> ago</span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center text-gray-400">No workflow runs yet. Create a patient and case to get started.</div>
    <% end %>
  </div>
</div>
