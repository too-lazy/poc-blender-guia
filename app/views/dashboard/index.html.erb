<div class="space-y-8">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-black text-gray-900">Dashboard</h1>
    <div class="flex gap-3">
      <%= link_to "🚀 Quick Process", new_quick_process_path, class: "brutalist-btn brutalist-btn-accent" %>
      <%= link_to "+ New Patient", new_patient_path, class: "brutalist-btn brutalist-btn-primary" %>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="brutalist-card p-6">
      <div class="text-xs font-black uppercase tracking-wider text-gray-500">Patients</div>
      <div class="text-4xl font-black text-gray-900 mt-2"><%= Patient.count %></div>
    </div>
    <div class="brutalist-card p-6">
      <div class="text-xs font-black uppercase tracking-wider text-gray-500">Cases</div>
      <div class="text-4xl font-black text-gray-900 mt-2"><%= Case.count %></div>
    </div>
    <div class="brutalist-card p-6">
      <div class="text-xs font-black uppercase tracking-wider text-gray-500">Workflow Runs</div>
      <div class="text-4xl font-black text-gray-900 mt-2"><%= WorkflowRun.count %></div>
    </div>
  </div>

  <!-- Recent Runs -->
  <div class="brutalist-card">
    <div class="px-6 py-4 border-b-2 border-black">
      <h2 class="text-lg font-black text-gray-900">Recent Workflow Runs</h2>
    </div>
    <% if @recent_runs.any? %>
      <div class="divide-y-2 divide-gray-200">
        <% @recent_runs.each do |run| %>
          <div class="px-6 py-4 flex items-center justify-between hover:bg-cream transition-colors">
            <div>
              <div class="font-bold text-gray-900"><%= run.case.patient&.name || "Quick process" %></div>
              <div class="text-sm text-gray-500"><%= run.case.description.truncate(60) %></div>
            </div>
            <div class="flex items-center gap-3">
              <%= render partial: "shared/status_badge", locals: { status: run.status } %>
              <span class="text-xs font-medium text-gray-400"><%= time_ago_in_words(run.created_at) %> ago</span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <p class="text-gray-400 text-lg font-bold">No workflow runs yet.</p>
        <p class="text-gray-400 text-sm mt-2">Create a patient and case, or use Quick Process to get started.</p>
      </div>
    <% end %>
  </div>
</div>
