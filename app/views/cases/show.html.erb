<div class="space-y-6">
  <!-- Breadcrumb -->
  <div class="text-sm font-medium text-slate-500 flex items-center gap-1.5">
    <%= link_to @patient.name, patient_path(@patient), class: "text-sky-500 hover:text-sky-600" %> ›
    <span class="text-slate-700">Caso</span>
  </div>

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= @case.description.truncate(80) %></h1>
      <div class="flex items-center gap-3 mt-2">
        <%= render partial: "shared/status_badge", locals: { status: @case.status } %>
        <span class="text-sm text-slate-500 font-medium">Creado hace <%= time_ago_in_words(@case.created_at) %></span>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Editar", edit_patient_case_path(@patient, @case),
          class: "bg-white hover:bg-sky-50 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium border border-sky-200 transition-all" %>
      <% if @case.stl_file.attached? %>
        <%= button_to "▶ Ejecutar Workflow", execute_workflow_patient_case_path(@patient, @case),
            method: :post,
            class: "bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm transition-all",
            data: { turbo_confirm: "¿Ejecutar el pipeline Blender en este STL?" } %>
      <% end %>
    </div>
  </div>

  <!-- STL Info -->
  <div class="bg-white border border-sky-100 rounded-xl p-6 shadow-sm">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">Archivo STL</h2>
    <% if @case.stl_file.attached? %>
      <div class="flex items-center gap-3">
        <span class="font-medium text-slate-900"><%= @case.stl_file.filename %></span>
        <span class="text-sm text-slate-500"><%= number_to_human_size(@case.stl_file.byte_size) %></span>
      </div>
    <% else %>
      <p class="text-slate-400 font-medium">Sin archivo STL. <%= link_to "Subir uno", edit_patient_case_path(@patient, @case), class: "text-sky-500 hover:text-sky-600 font-medium" %>.</p>
    <% end %>
  </div>

  <!-- Workflow Runs -->
  <div class="bg-white border border-sky-100 rounded-xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-sky-50">
      <h2 class="text-slate-900 font-semibold">Workflow Runs</h2>
    </div>
    <% if @workflow_runs.any? %>
      <div class="divide-y divide-sky-50">
        <% @workflow_runs.each do |run| %>
          <%= link_to patient_case_workflow_run_path(@patient, @case, run), class: "block px-6 py-4 hover:bg-sky-50/30 transition-colors" do %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <%= render partial: "shared/status_badge", locals: { status: run.status } %>
                <span class="text-sm font-medium text-slate-700">Run #<%= run.id %></span>
                <% if run.duration %>
                  <span class="text-xs text-slate-400 font-medium">(<%= "%.1f" % run.duration %>s)</span>
                <% end %>
              </div>
              <div class="flex items-center gap-3">
                <% if run.render_output.attached? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-sky-100 text-sky-700 font-medium">📸 Render</span>
                <% end %>
                <span class="text-xs text-slate-400 font-medium"><%= time_ago_in_words(run.created_at) %> ago</span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <p class="text-slate-400 font-medium">Sin ejecuciones aún.</p>
        <p class="text-slate-400 text-sm mt-2">Ejecuta el workflow para generar un render.</p>
      </div>
    <% end %>
  </div>
</div>
