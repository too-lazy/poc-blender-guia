<%= form_with(model: [patient, dental_case], class: "space-y-5") do |f| %>
  <% if dental_case.errors.any? %>
    <div class="bg-red-100 border-2 border-black text-red-900 px-4 py-3 font-bold text-sm shadow-brutal-sm">
      <% dental_case.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :description, class: "block text-sm font-bold text-gray-700 mb-2" %>
    <%= f.text_area :description, rows: 3, class: "brutalist-input w-full", required: true %>
  </div>

  <div>
    <%= f.label :stl_file, "STL File", class: "block text-sm font-bold text-gray-700 mb-2" %>
    <div class="brutalist-card !border-dashed !border-2 p-6 text-center bg-cream">
      <%= f.file_field :stl_file, accept: ".stl",
          class: "block w-full text-sm text-gray-600 file:mr-4 file:py-3 file:px-6 file:border-2 file:border-black file:text-sm file:font-bold file:bg-accent file:text-black file:shadow-brutal-sm hover:file:bg-accent-hover file:cursor-pointer file:transition-colors" %>
    </div>
    <% if dental_case.stl_file.attached? %>
      <p class="text-xs font-bold text-green-700 mt-2">✓ <%= dental_case.stl_file.filename %> (<%= number_to_human_size(dental_case.stl_file.byte_size) %>)</p>
    <% end %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "brutalist-btn brutalist-btn-primary cursor-pointer" %>
    <%= link_to "Cancel", patient_path(patient), class: "brutalist-btn brutalist-btn-ghost" %>
  </div>
<% end %>
