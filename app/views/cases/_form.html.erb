<%= form_with(model: [patient, dental_case], class: "space-y-4") do |f| %>
  <% if dental_case.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm">
      <% dental_case.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", required: true %>
  </div>

  <div>
    <%= f.label :stl_file, "STL File", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.file_field :stl_file, accept: ".stl", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
    <% if dental_case.stl_file.attached? %>
      <p class="text-xs text-green-600 mt-1">✓ <%= dental_case.stl_file.filename %> (<%= number_to_human_size(dental_case.stl_file.byte_size) %>)</p>
    <% end %>
  </div>

  <div class="flex items-center space-x-3 pt-2">
    <%= f.submit class: "bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", patient_path(patient), class: "text-gray-500 hover:text-gray-700 text-sm" %>
  </div>
<% end %>
